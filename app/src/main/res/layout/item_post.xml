<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="30dp"
    android:layout_margin="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgMain"
            android:layout_width="0dp"
            android:layout_height="350dp"
            android:layout_margin="6dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeRounded16"
            tools:srcCompat="@drawable/img_outfit" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:text="user_name"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@+id/imgMain"
            app:layout_constraintTop_toBottomOf="@+id/imgMain" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Outfit Description"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintStart_toStartOf="@+id/lblUser"
            app:layout_constraintTop_toBottomOf="@+id/lblUser"
            android:textColor="@android:color/black" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgTopIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@+id/lblDescription"
            app:layout_constraintTop_toBottomOf="@+id/lblDescription"
            app:srcCompat="@drawable/img_shirt" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="zara"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgTopIcon"
            app:layout_constraintStart_toEndOf="@+id/imgTopIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgBottomIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/imgTopIcon"
            app:layout_constraintStart_toEndOf="@+id/lblTop"
            app:layout_constraintTop_toBottomOf="@+id/lblDescription"
            app:srcCompat="@drawable/img_pants" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="castro"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgBottomIcon"
            app:layout_constraintStart_toEndOf="@+id/imgBottomIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgDressIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/imgBottomIcon"
            app:layout_constraintStart_toEndOf="@+id/lblBottom"
            app:layout_constraintTop_toBottomOf="@+id/lblDescription"
            app:srcCompat="@drawable/img_dress" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblDress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="castro"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgDressIcon"
            app:layout_constraintStart_toEndOf="@+id/imgDressIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgTargetIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/imgBottomIcon"
            app:layout_constraintStart_toEndOf="@+id/lblDress"
            app:layout_constraintTop_toBottomOf="@+id/lblDescription"
            app:srcCompat="@drawable/img_target" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lbTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="work"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgTargetIcon"
            app:layout_constraintStart_toEndOf="@+id/imgTargetIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgJacketIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="10dp"
            app:layout_constraintStart_toStartOf="@+id/imgTopIcon"
            app:layout_constraintTop_toBottomOf="@+id/imgTopIcon"
            app:srcCompat="@drawable/img_jacket" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblJacket"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="zara"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgJacketIcon"
            app:layout_constraintStart_toEndOf="@+id/imgJacketIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgShoesIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            app:layout_constraintBottom_toBottomOf="@+id/imgJacketIcon"
            app:layout_constraintStart_toEndOf="@+id/lblJacket"
            app:layout_constraintTop_toTopOf="@+id/imgJacketIcon"
            android:layout_marginStart="15dp"
            app:srcCompat="@drawable/img_shoes" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblShoes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="castro"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgShoesIcon"
            app:layout_constraintStart_toEndOf="@+id/imgShoesIcon" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/imgBagIcon"
            android:layout_width="14dp"
            android:layout_height="14dp"
            app:layout_constraintBottom_toBottomOf="@+id/imgShoesIcon"
            app:layout_constraintStart_toEndOf="@+id/lblShoes"
            app:layout_constraintTop_toTopOf="@+id/imgShoesIcon"
            android:layout_marginStart="15dp"
            app:srcCompat="@drawable/img_bag" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/lblBag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="zara"
            android:textSize="14sp"
            app:layout_constraintBaseline_toBottomOf="@id/imgBagIcon"
            app:layout_constraintStart_toEndOf="@+id/imgBagIcon" />

