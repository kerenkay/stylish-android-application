        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLike"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:padding="0dp"
            app:icon="@drawable/ic_heart"
            app:iconGravity="textStart"
            app:iconTint="#000000"
            app:layout_constraintEnd_toEndOf="@+id/imgMain"
            app:layout_constraintTop_toBottomOf="@+id/imgMain"/>

        <TextView
            android:id="@+id/lblLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@+id/btnLike"
            app:layout_constraintStart_toStartOf="@id/btnLike"
            app:layout_constraintTop_toBottomOf="@+id/btnLike" />


